# ==========================================
# 牛剑面试辅导平台 - 环境变量配置
# ==========================================

# ----- AI Provider 选择 -----
# "poe"    = 使用 POE API（推荐，可访问多个模型）
# "anthropic" = 直接使用 Claude API
AI_PROVIDER=poe

# ----- POE API 配置（AI_PROVIDER=poe 时需要）-----
# 获取方式：访问 https://poe.com/api_key（需要 POE 付费订阅）
# 支持模型：Claude-Opus-4.1 / Claude-Sonnet-4 / GPT-4o-2025 等
POE_API_KEY=你的POE_API_KEY在这里
POE_MODEL=claude-sonnet-4.6

# ----- Anthropic API 配置（AI_PROVIDER=anthropic 时需要）-----
# 获取方式：访问 https://console.anthropic.com/
ANTHROPIC_API_KEY=你的ANTHROPIC_API_KEY在这里

# ----- 服务器配置 -----
# 后端端口（默认 8000）
PORT=8000
# 前端地址（用于 CORS，多个用逗号分隔）
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
